# FreshAF configuration — copy to .env and fill in for production.

PORT=5757
# Set to your public https URL in production (used for PayFast redirects + webhooks)
BASE_URL=http://localhost:5757
# Set to "production" on the host (enables secure cookies behind TLS)
NODE_ENV=development

# Admin login (seeded on first run only; delete data/freshaf.db to re-seed)
ADMIN_EMAIL=admin@freshaf.co.za
ADMIN_PASSWORD=FreshAF!Admin2026

# PayFast merchant credentials — leave blank to run card payments in sandbox mode.
# Register at https://www.payfast.co.za, then paste your keys here to go live.
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=

# Optional: pin the JWT secret (otherwise one is generated and stored in data/jwt.secret)
JWT_SECRET=
